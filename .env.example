## Backend (Node.js)
# Used by `backend/src/index.js`
PORT=5000

## MongoDB Connection
# For Docker: mongodb://mongodb:27017/wallet-sync
# For Local:  mongodb://localhost:27017/wallet-sync
# For Cloud:  mongodb+srv://USER:PASSWORD@CLUSTER_HOST/wallet-sync
MONGO_URI=mongodb://mongodb:27017/wallet-sync

PYTHON_SERVER_URL=http://python-server:8000

## Python server (FastAPI)
# Used by `python-server/app/config/settings.py`
DB_NAME=wallet-sync

## Optional external API keys (leave blank to start containers)
GOLDRUSH_API_KEY=
TATUM_API_KEY=

## Optional (used if/when auth is added)
JWT_SECRET=dev-secret-change-me

